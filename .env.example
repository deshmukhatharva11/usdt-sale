# =========================================================
# PVC Meta — Environment Configuration
# Copy this file to .env and CHANGE ALL VALUES marked [CHANGE]
# =========================================================

# Server Configuration
PORT=3000
NODE_ENV=development

# ─── PostgreSQL ──────────────────────────────────────────
DB_HOST=127.0.0.1
DB_NAME=pvc_meta
DB_USER=postgres
DB_PASS=CHANGE_ME_strong_db_password            # [CHANGE] Use: openssl rand -hex 16
DB_PORT=6432

# ─── Redis ───────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_strong_redis_password   # [CHANGE] Use: openssl rand -hex 16

# ─── Smart Contracts (update after deployment) ───────────
MINE_CONTRACT_ADDRESS=
BALANCE_FETCHER_ADDRESS=
USDT_TOKEN_ADDRESS=0x55d398326f99059fF775485246999027B3197955

# ─── Security ────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_64_char_hex_secret          # [CHANGE] Use: openssl rand -hex 32
JWT_EXPIRES_IN=2h

# Admin credentials — CHANGE IMMEDIATELY after first login
ADMIN_USERNAME=admin                             # [CHANGE]
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password   # [CHANGE]

# ─── Blockchain ──────────────────────────────────────────
BSC_CHAIN_ID=56
BSC_RPC_URL=https://bsc-dataseed1.binance.org/
BSC_RPC_URLS=https://bsc-dataseed1.binance.org/,https://bsc-dataseed2.binance.org/,https://bsc-dataseed3.binance.org/,https://bsc-dataseed4.binance.org/
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545/

# Private Key for Contract Deployment (DO NOT COMMIT)
PRIVATE_KEY=

# ─── CORS ────────────────────────────────────────────────
# Comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Rate Limiting ───────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── PgAdmin (optional, dev only) ───────────────────────
PGADMIN_EMAIL=admin@pvcmeta.io
PGADMIN_PASSWORD=CHANGE_ME_pgadmin_password      # [CHANGE]
